# Copy this file to .streamlit/secrets.toml and fill in real values.
# Never commit the real secrets.toml.

# --- LLM ---
# One of: "github" (default), "openai", "anthropic"
LLM_PROVIDER = "github"
LLM_MODEL    = "openai/gpt-4o-mini"

# GitHub PAT with access to GitHub Models (https://models.github.ai).
GITHUB_TOKEN = ""

# Optional fallbacks.
OPENAI_API_KEY    = ""
ANTHROPIC_API_KEY = ""

# --- Broker backend ---
# One of: "sandbox", "alpaca_paper", "dual" (recommended)
BROKER_BACKEND = "dual"

# Required when BROKER_BACKEND is "alpaca_paper" or "dual".
ALPACA_API_KEY_ID              = ""
ALPACA_SECRET_KEY              = ""
ALPACA_PAPER                   = "true"
STOCK_REC_MCP_TRADING_ENABLED  = "true"
STOCK_REC_MAX_ORDER_USD        = "1000"     # per-order USD cap on Alpaca leg; 0 disables
STOCK_REC_MAX_SYMBOL_PCT       = "20"       # per-symbol % of equity cap; 0 disables
STOCK_REC_ALLOW_LEVERAGED      = "false"    # true = permit leveraged/inverse/vol ETFs (paper only)

# --- Upstream sibling-repo paths (absolute) ---
SHORT_TERM_TRADER_PATH = "/Users/girikmalik/Documents/girik_academic_resources/personal_projects/short-term-trader"
STOCK_RECOMMENDER_PATH = "/Users/girikmalik/Documents/girik_academic_resources/personal_projects/stock-recommender"

# --- Capital & split ---
CAPITAL_TOTAL  = "100000"
SPLIT_DAY_PCT  = "30"

# --- Optional upstream API keys (passed through to MCP subprocesses) ---
FINNHUB_API_KEY      = ""
ALPHAVANTAGE_API_KEY = ""
